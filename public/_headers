# Cloudflare Pages headers — long-cache assets, no-cache HTML, and a site CSP.
# CSP notes: 'unsafe-inline' = Starlight's inline theme script; 'unsafe-eval' +
# blob: = the embedded /terminal-demo.html bundle (it string-evals its runtime and
# materializes its own inlined React/asset bytes via blob: — no CDN) — and
# 'unsafe-eval' also covers Pagefind's wasm search. Fonts are self-hosted
# (@fontsource, same-origin), so there is NO third-party origin in this policy at
# all; it blocks every other origin, clickjacking, and base-uri/object/form-action
# injection.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; img-src 'self' data: blob: https:; font-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; worker-src 'self' blob:; connect-src 'self' blob:

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=86400

/og.svg
  Cache-Control: public, max-age=86400

/og.png
  Cache-Control: public, max-age=86400

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

---
// Animated `selvedge blame` reveal, embedded from /terminal-demo.html
// (a self-contained bundle — fonts + runtime inlined — that lives in public/).
//
// The demo is a fluid `min-height: 100vh` page, so locking the iframe to a
// fixed aspect-ratio would clip its reasoning box on narrow screens. Instead
// the script below auto-fits the iframe to the demo's real content height.
// The demo and this page are same-origin (both served from selvedge.sh), so
// the parent can read the inner document height directly.
---

<figure class="terminal-demo">
  <div class="terminal-demo__frame">
    <iframe
      id="selvedge-terminal-demo"
      src="/terminal-demo.html"
      title="Animated selvedge blame demo — the reasoning behind a change, revealed live in the terminal"
      loading="lazy"
      style="height: 640px;"></iframe>
  </div>
  <figcaption class="terminal-demo__caption">
    <code>selvedge blame user_tier_v2</code> surfaces the reasoning the agent
    recorded for a change — the <em>why</em>, captured live, right in the terminal.
  </figcaption>
</figure>

<style>
  .terminal-demo {
    margin: 1.75rem 0 0;
  }
  .terminal-demo__frame {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 12px;
    overflow: hidden;
    background: var(--selvedge-ecru);
  }
  /* In dark mode the light terminal is a bright slab against the darkest part
   * of the page. Wrap it in a dark bezel so it reads as a screen, not a hole. */
  :global(:root[data-theme="dark"]) .terminal-demo__frame {
    background: var(--selvedge-indigo-deep);
    border-color: var(--sl-color-hairline);
    padding: 10px;
  }
  .terminal-demo__frame iframe {
    display: block;
    width: 100%;
    border: 0;
  }
  .terminal-demo__caption {
    margin-top: 0.7rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--sl-color-gray-3);
    text-align: center;
  }
  .terminal-demo__caption code {
    font-size: 0.85em;
  }
</style>

<script>
  // Auto-fit the iframe to the demo's true content height (same-origin) so the
  // reasoning box — the whole point of the reveal — is never clipped at any
  // viewport width. 640px is just the pre-load fallback; the demo needs JS to
  // render anyway, so this always runs.
  const frame = document.getElementById("selvedge-terminal-demo") as HTMLIFrameElement | null;
  const reduceMotion = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches ?? false;
  if (frame) {
    const fit = () => {
      try {
        const doc = frame.contentWindow?.document;
        const h = doc?.body ? doc.body.scrollHeight : 0;
        if (h && Math.abs(h - frame.clientHeight) > 2) frame.style.height = h + "px";
      } catch {
        /* cross-origin or not ready — keep the CSS fallback height */
      }
    };
    // The reasoning box reveals ~9s into the animation, so poll fit() briefly
    // (every 250ms for ~12s) — a one-shot observer can miss that late growth.
    const pollFit = () => {
      let n = 0;
      const iv = setInterval(() => { fit(); if (++n > 48) clearInterval(iv); }, 250);
    };
    // Replay the reveal via the demo's exposed restart hook (same-origin).
    const replay = () => {
      try {
        const w = frame.contentWindow as any;
        if (w && typeof w.selvedgeReplay === "function") { w.selvedgeReplay(); pollFit(); }
      } catch { /* no-op */ }
    };

    frame.addEventListener("load", () => {
      fit();
      try {
        const body = frame.contentWindow?.document.body;
        if (body) new ResizeObserver(fit).observe(body);
      } catch { /* no-op */ }
      pollFit();
    });
    let t: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => {
      clearTimeout(t);
      frame.style.height = "200px"; // allow shrink on rotate, then re-grow to fit
      t = setTimeout(fit, 120);
    });

    // Replay the animation each time the demo scrolls into view. It plays once
    // on first load (the demo's own mount), then replays on every re-entry.
    // The first appearance is skipped so it doesn't double up with that play.
    // Skipped under prefers-reduced-motion so the animation never re-triggers
    // for users who asked for less movement.
    if (!reduceMotion && "IntersectionObserver" in window) {
      let visible = false, seen = false;
      new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !visible) {
            visible = true;
            if (seen) replay();
            seen = true;
          } else if (!e.isIntersecting) {
            visible = false;
          }
        });
      }, { threshold: 0.3 }).observe(frame);
    }
  }
</script>

---
// Custom hero shown on the landing page only.
// Uses Starlight's hero data (title/tagline/actions) + adds the selvedge stripe
// + an inline install command. Wraps everything in semantic HTML so it
// matches Starlight's accessibility expectations.
import type { Props } from "@astrojs/starlight/props";

const { entry } = Astro.props;
const data = entry.data.hero;
---

<section class="selvedge-hero">
  <div class="selvedge-hero__wordmark">
    <span class="selvedge-hero__stripe" aria-hidden="true"></span>
    <h1 class="selvedge-hero__title">selvedge</h1>
  </div>

  {data?.tagline && <p class="selvedge-hero__tag">{data.tagline}</p>}

  <p class="selvedge-hero__sub">
    A local MCP server. AI coding agents (Claude Code, Cursor, Copilot) call it
    as they work to log the <em>why</em> behind every change — captured live,
    in the same context that produced it. Stays in a SQLite file under
    <code>.selvedge/</code> next to your code.
  </p>

  <code class="selvedge-hero__install" aria-label="Install command">
    pip install selvedge
  </code>

  {data?.actions && data.actions.length > 0 && (
    <div class="selvedge-hero__cta">
      {data.actions.map((a: any) => (
        <a
          href={a.link}
          class={a.variant === "primary" ? "primary" : "secondary"}
        >
          {a.text}
        </a>
      ))}
    </div>
  )}
</section>

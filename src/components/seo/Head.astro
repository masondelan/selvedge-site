---
// Custom <head> overrides for Starlight.
//
// What this fixes / adds:
//   - og:type=website on the homepage (default Starlight emits "article" everywhere,
//     which is wrong for the root page — Google honors og:type for entity typing).
//   - Explicit twitter:title and twitter:description (Starlight currently omits them
//     and relies on fallback; explicit is safer across crawlers).
//   - JSON-LD structured data:
//       * Organization (sitewide) — gives Google a knowledge-graph entity for Selvedge
//         with sameAs links to GitHub, PyPI, X.
//       * WebSite (sitewide) — declares the site name + potentialAction so Google can
//         render the sitelinks search box.
//       * SoftwareApplication (homepage only) — Selvedge is a dev tool; this is the
//         canonical schema for software listings and unlocks rich results.
//       * FAQPage (FAQ page only) — inline strings kept in sync with the FAQ page.
//         FAQPage is a known eligible rich-result type.
//
// Registration:
//   In astro.config.mjs, set:
//     starlight({
//       ...
//       components: {
//         Head: './src/components/seo/Head.astro',
//       },
//     })
//   Then Starlight's <Default /> rendering is preserved — we only append to <head>.

import Default from '@astrojs/starlight/components/Head.astro';

const SITE = 'https://selvedge.sh';
const url = Astro.url.pathname;
const isHome = url === '/' || url === '';
const isFaq = url.startsWith('/project/faq');

// The canonical product one-liner. Kept identical to the README's lead so the
// SoftwareApplication description never drifts from the source of truth.
const ONE_LINER =
  'Long-term memory for AI-coded codebases. A git blame for AI agents — but for the why, not just which line which model touched. Captured live, by the agent, as the change happens.';

// Pull page-level metadata from Starlight's frontmatter so we can re-emit
// what we need without duplicating Starlight's own logic.
const route = (Astro.locals as any)?.starlightRoute;
const entry = route?.entry;
const data = entry?.data ?? {};
const pageTitle = data.title ?? 'selvedge';
const pageDescription =
  data.description ??
  'A local MCP server that AI coding agents call as they work — logging the why behind every change into a SQLite file under .selvedge/ next to your code.';

// Per-page JSON-LD hint (see src/content.config.ts). Pages default to
// TechArticle; setup/tutorial pages declare structuredData.type: howto.
// Pages with a visible FAQ section declare structuredData.faq — the answers
// must match the visible page text or the page loses rich-result eligibility.
const structuredData = data.structuredData ?? { type: 'techarticle' };
const faqItems: { question: string; answer: string }[] = structuredData.faq ?? [];
const lastUpdated: Date | undefined = route?.lastUpdated;
const pageUrl = `${SITE}${url}`;

// --- Structured data -------------------------------------------------------

const organization = {
  '@type': 'Organization',
  '@id': `${SITE}/#org`,
  name: 'Selvedge',
  url: SITE,
  logo: `${SITE}/favicon.svg`,
  sameAs: [
    'https://github.com/masondelan/selvedge',
    'https://pypi.org/project/selvedge/',
    'https://x.com/notmason__',
  ],
};

const website = {
  '@type': 'WebSite',
  '@id': `${SITE}/#website`,
  url: SITE,
  name: 'Selvedge',
  publisher: { '@id': `${SITE}/#org` },
  inLanguage: 'en',
};

const softwareApplication = {
  '@type': 'SoftwareApplication',
  '@id': `${SITE}/#software`,
  name: 'Selvedge',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux, Windows',
  url: SITE,
  description: ONE_LINER,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  softwareRequirements: 'Python 3.10+',
  downloadUrl: 'https://pypi.org/project/selvedge/',
  publisher: { '@id': `${SITE}/#org` },
};

// Per-page content node. The homepage is a SoftwareApplication listing and the
// FAQ page carries FAQPage (below), so neither gets an article/howto node.
// Everything else is a TechArticle unless it opts into HowTo.
let pageNode: Record<string, unknown> | null = null;
if (!isHome && !isFaq) {
  if (structuredData.type === 'howto') {
    pageNode = {
      '@type': 'HowTo',
      '@id': `${pageUrl}#howto`,
      name: pageTitle,
      description: pageDescription,
      url: pageUrl,
      inLanguage: 'en',
      publisher: { '@id': `${SITE}/#org` },
      ...(structuredData.steps?.length
        ? {
            step: structuredData.steps.map(
              (s: { name: string; text: string; url?: string }, i: number) => ({
                '@type': 'HowToStep',
                position: i + 1,
                name: s.name,
                text: s.text,
                ...(s.url ? { url: `${SITE}${s.url}` } : {}),
              }),
            ),
          }
        : {}),
    };
  } else {
    pageNode = {
      '@type': 'TechArticle',
      '@id': `${pageUrl}#article`,
      headline: pageTitle,
      description: pageDescription,
      url: pageUrl,
      inLanguage: 'en',
      author: { '@id': `${SITE}/#org` },
      publisher: { '@id': `${SITE}/#org` },
      isPartOf: { '@id': `${SITE}/#website` },
      ...(lastUpdated ? { dateModified: lastUpdated.toISOString() } : {}),
    };
  }
}

// Frontmatter-declared FAQ (structuredData.faq) → FAQPage node. The dedicated
// /project/faq page keeps its hand-synced block below; this is for content
// pages that carry a visible FAQ section (e.g. /prior-attempts).
const faqNode =
  !isFaq && faqItems.length
    ? {
        '@type': 'FAQPage',
        '@id': `${pageUrl}#faq`,
        mainEntity: faqItems.map((f) => ({
          '@type': 'Question',
          name: f.question,
          acceptedAnswer: { '@type': 'Answer', text: f.answer },
        })),
      }
    : null;

// Build a graph so all entities share IDs and Google can connect them.
const graph: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@graph': isHome
    ? [organization, website, softwareApplication]
    : [organization, website, ...(pageNode ? [pageNode] : []), ...(faqNode ? [faqNode] : [])],
};
---

<Default><slot /></Default>

{/* og:type override — Starlight defaults to article; fix to website on the root */}
{isHome && <meta property="og:type" content="website" />}

{/* Explicit Twitter fields (better than relying on og:* fallback) */}
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDescription} />
<meta name="twitter:site" content="@notmason__" />
<meta name="twitter:creator" content="@notmason__" />

{/* Sitewide JSON-LD graph */}
<script
  type="application/ld+json"
  set:html={JSON.stringify(graph)}
/>

{/* FAQPage schema, emitted only on /project/faq. Inline list so the schema does
    not depend on DOM-scraping at runtime — Google's crawler does not execute JS
    for structured data discovery. Keep these strings in sync with the FAQ page. */}
{isFaq && (
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      // Synced to src/content/docs/project/faq.md on 2026-06-10.
      // Google requires FAQPage markup to match the visible answer text —
      // if you edit the FAQ page copy, re-sync these strings or the page
      // loses FAQ rich-result eligibility.
      mainEntity: [
        {
          '@type': 'Question',
          name: "What's the one-line description?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Selvedge is a local MCP server that captures the why behind every AI-written change, in the same context window that produced the change.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is it open source?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. MIT-licensed. Source: github.com/masondelan/selvedge.',
          },
        },
        {
          '@type': 'Question',
          name: 'Where does my data live?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "In a SQLite file under .selvedge/selvedge.db next to your code (or ~/.selvedge/selvedge.db if no project DB is found and you didn't selvedge init). It does not leave your machine. There's no telemetry, no remote endpoint, no opt-in or opt-out — the data simply doesn't go anywhere by default. The roadmap includes an optional HTTP layer (v0.4.1) for self-hosted team servers; it's never sending data to us.",
          },
        },
        {
          '@type': 'Question',
          name: 'Can I commit .selvedge/ to git?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Yes — and for most projects, it's a good idea. SQLite + WAL handles concurrent CI checkouts well, and committing the DB means everyone on the team sees the same history. For monorepos where each microservice maintains its own history independently, you might prefer to .gitignore everything except .selvedge/.gitkeep.",
          },
        },
        {
          '@type': 'Question',
          name: "What if I'm using a different AI tool?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Selvedge works with anything that speaks MCP. Claude Code, Cursor, Copilot are detected automatically by selvedge setup. For others, follow the manual install: add the selvedge server to the tool's MCP config and drop the agent-instructions block (selvedge prompt) into the tool's system prompt. If your AI tool doesn't support MCP, Selvedge can't capture live — but you can still use the CLI for manual logging via selvedge log and import historical migrations via selvedge import.",
          },
        },
        // The visible "How do I stop my agent repeating a mistake..." entry on
        // the FAQ page is deliberately NOT marked up here: the same question is
        // marked up on /prior-attempts (its canonical page), and Google says a
        // FAQ repeated across pages should carry markup on only one of them.
        {
          '@type': 'Question',
          name: 'Why MCP instead of a plain CLI hook?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Because MCP gives the agent access to its own history. Your agent can call selvedge blame and selvedge diff while it's working — so when it goes to modify a column it changed last sprint, it can read the prior reasoning before deciding. A plain CLI hook captures one direction (write). MCP captures both (write + read). For an AI-coded codebase that lives for years, the read direction is at least as valuable as the write direction.",
          },
        },
        {
          '@type': 'Question',
          name: 'Does the agent really call log_change reliably?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "That's exactly what selvedge stats answers. Per-agent breakdown of total calls, log_change calls, coverage ratio, and missing-reasoning count. If your agent's coverage is low, the system prompt needs strengthening — see docs/fallbacks.md in the source repo for guidance.",
          },
        },
        {
          '@type': 'Question',
          name: 'What\'s "reasoning quality validation"?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'log_change runs incoming reasoning through a regex-and-length validator. It catches: empty reasoning, reasoning under 20 characters, and generic placeholders ("user request", "as requested", "per request", "done", "n/a", "none", "todo", "see diff"/"see code"/"see pr", "fix"/"fixed", "add"/"added", "remove"/"removed", "update"/"updated", "change"/"changed"). Failed reasoning still gets logged (warnings are advisory) but appears in the default selvedge stats output as a low-quality-reasoning count. The point is to surface the agent silently shipping low-quality logs so you can fix the prompt.',
          },
        },
        {
          '@type': 'Question',
          name: 'Why no LLM in core?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Two reasons. Templated output is deterministic — a regex validator behaves the same on every commit, while an LLM in the loop introduces non-determinism that's miserable to test. And the local-first dependency budget — adding an LLM hop means an API key, a network dependency, latency, and ongoing cost. Selvedge installs in three deps for a reason. PRs that add LLM calls inside core get rejected.",
          },
        },
        {
          '@type': 'Question',
          name: 'Will my old database keep working when I upgrade?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Yes. Selvedge has a versioned migration system since v0.3.1, and every migration is recorded in a schema_migrations table. Pre-v0.3.1 databases are bootstrapped without re-running DDL that would error. If you're on v0.2.x and an upgrade misbehaves, run selvedge doctor — it'll tell you exactly which migration step is failing.",
          },
        },
        {
          '@type': 'Question',
          name: 'Why "selvedge"?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "The selvedge is the finished, self-bound edge of a roll of fabric — woven during the fabric's creation and visible afterwards as the dense, color-banded edge that doesn't fray. The brand pairs that with a thin red stripe in tribute to the red selvedge thread on classic Japanese denim. The product analogy is direct: capture the edge of the change as it's being made, and it survives long after the diff has been incorporated and forgotten. Like the selvedge, the why is woven in at creation time — not stitched on later.",
          },
        },
      ],
    })}
  />
)}
